{
  "name": "crosslink-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.dev.ts",
    "build": "vue-tsc --noEmit && vite build --config config/vite.config.prod.ts",
    "preview": "vite preview --config config/vite.config.prod.ts",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,less}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{vue,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{less,css,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.57.0",
    "@vueuse/core": "^12.0.0",
    "axios": "^1.7.0",
    "dayjs": "^1.11.0",
    "echarts": "^5.5.0",
    "nprogress": "^0.2.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.0",
    "vue-i18n": "^9.14.4",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^5.2.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.1",
    "husky": "^9.1.7",
    "less": "^4.2.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.0.0",
    "vite-svg-loader": "^5.1.0",
    "vue-tsc": "^2.2.0"
  }
}
